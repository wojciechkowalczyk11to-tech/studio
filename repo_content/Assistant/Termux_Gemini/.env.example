# ========================================================
# Termux AI Agent - Environment Variables Template
# ========================================================
# IMPORTANT: Copy this file to .env and fill in your credentials
#
# cp .env.example .env
# nano .env  # Fill in your actual values
#

# ===== GOOGLE CLOUD PROJECT =====
# Your GCP Project ID (REQUIRED)
# Get from: https://console.cloud.google.com
GCP_PROJECT_ID="your-project-id-here"

# Vertex AI Search Datastore ID (REQUIRED)
# Get from: https://console.cloud.google.com/gen-app-builder/engines
VERTEX_DATASTORE_ID="your-datastore-id-here"

# Optional: Additional datastores for specialized search
VERTEX_DATASTORE_DOCS=""
VERTEX_DATASTORE_CODE=""

# ===== GEMINI API =====
# Gemini API Key (REQUIRED)
# Get from: https://makersuite.google.com/app/apikey
GEMINI_API_KEY="your-gemini-api-key-here"

# ===== GOOGLE CLOUD AUTHENTICATION =====
# Service Account JSON Key File Path (REQUIRED)
# Download from: https://console.cloud.google.com/iam-admin/serviceaccounts
# Save as: config/service-account-key.json
GOOGLE_APPLICATION_CREDENTIALS="config/service-account-key.json"

# ===== OPTIONAL SETTINGS =====
# Agent settings (override config/agent_config.yaml)
# AGENT_NAME="TermuxAgent"
# AGENT_REASONING_DEPTH="7"
# AGENT_IMPROVEMENT_FREQUENCY="5"

# Cost monitoring
# COST_ALERT_EMAIL=""  # Email for budget alerts
# COST_ALERT_WEBHOOK=""  # Slack/Discord webhook for alerts

# ===== DEVELOPMENT =====
# Set to "true" to enable debug mode
# DEBUG_MODE="false"

# Set to "true" to use mock APIs (for testing without credentials)
# MOCK_API_CALLS="false"
