# =========================
# Core application
# =========================
APP_ENV=development
APP_DEBUG=false
APP_HOST=0.0.0.0
APP_PORT=8000
SECRET_KEY=replace_with_random_secret_key
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=120

# =========================
# Database
# =========================
POSTGRES_DB=nexus
POSTGRES_USER=nexus
POSTGRES_PASSWORD=replace_with_postgres_password
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+psycopg://nexus:replace_with_postgres_password@postgres:5432/nexus

# =========================
# Redis
# =========================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_URL=redis://redis:6379/0

# =========================
# Telegram bot
# =========================
TELEGRAM_BOT_TOKEN=replace_with_telegram_bot_token
TELEGRAM_WEBHOOK_URL=https://example.com/telegram/webhook
TELEGRAM_ADMIN_IDS=123456789,987654321

# =========================
# AI providers
# =========================
GOOGLE_API_KEY=replace_with_google_api_key
GOOGLE_GENAI_USE_VERTEX=true
GCP_PROJECT_ID=replace_with_gcp_project_id
GCP_REGION=us-central1
VERTEX_LOCATION=us-central1
OPENAI_API_KEY=replace_with_openai_api_key
ANTHROPIC_API_KEY=replace_with_anthropic_api_key
DEEPSEEK_API_KEY=replace_with_deepseek_api_key
XAI_API_KEY=replace_with_xai_api_key
OPENROUTER_API_KEY=replace_with_openrouter_api_key

# =========================
# MCP / Cloudflare
# =========================
CF_API_TOKEN=replace_with_cloudflare_api_token
CF_ACCOUNT_ID=replace_with_cloudflare_account_id
CF_ZONE_ID=replace_with_cloudflare_zone_id
CLOUDFLARE_TUNNEL_ID=replace_with_tunnel_id
D1_DATABASE_ID=89b8f6fe-d069-4369-92cb-c203de51ac6f

# =========================
# GitHub and Vercel integrations
# =========================
GITHUB_TOKEN=replace_with_github_token
GITHUB_REPOSITORY_OWNER=replace_with_github_username_or_org
VERCEL_TOKEN=replace_with_vercel_token
VERCEL_TEAM_ID=replace_with_vercel_team_id

# =========================
# GCP deployment
# =========================
GOOGLE_APPLICATION_CREDENTIALS=/app/credentials/gcp-service-account.json
CLOUD_RUN_SERVICE_BACKEND=nexus-backend
CLOUD_RUN_SERVICE_BOT=nexus-telegram-bot

# =========================
# Observability
# =========================
SENTRY_DSN=replace_with_sentry_dsn
LOG_LEVEL=INFO
PROMETHEUS_ENABLED=true

# =========================
# Billing / limits
# =========================
COST_ALERT_DAILY_USD=1.0
DEFAULT_MODEL=gemini-3.0-flash-preview
DEFAULT_THINKING_LEVEL=medium
